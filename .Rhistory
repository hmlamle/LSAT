Peaks_div
Peaks_div <- ggplot()+
geom_line(data = taxonomic_averages, aes(x = Date, y = simpson), color = "orange")+
geom_line(data = Forereef, aes(x = Date, y = Phosphate), color = "blue")+
geom_point(data=peaks,aes(x = as.POSIXct(row.names(peaks)), y = V1),
colour='red', size=4)+
scale_y_continuous(
name = "Phosphorus Concentration",
sec.axis = sec_axis(~., name = "Simpson Diversity Index"),
breaks = seq(0, 0.24, by = 0.02),  # Set breaks for phosphorus concentration
labels = seq(0, 0.24, by = 0.02),  # Set labels for phosphorus concentration
limits = c(0, 0.24)
) +
labs(color = "Variable") +
theme_minimal()
